# --- Database ---
# Switched to Postgres for the Vercel stakeholder demo (Vercel's serverless functions can't
# durably write a local SQLite file). Use any Postgres connection string here — e.g. a free
# Neon (neon.tech) or Supabase project. Needed for local dev too now, since the datasource
# provider in prisma/schema.prisma is postgresql for both environments.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js / NextAuth v5 ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
# Set this to your actual deployed URL on Vercel (e.g. https://your-project.vercel.app).
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (see README "Google OAuth Setup" section) ---
GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_SECRET="your-google-client-secret"

# --- Stripe (test mode keys from your Stripe dashboard) ---
STRIPE_SECRET_KEY="replace-with-your-stripe-test-secret-key"
STRIPE_WEBHOOK_SECRET="replace-with-your-stripe-webhook-signing-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="replace-with-your-stripe-test-publishable-key"

# --- SMTP (password reset emails). Leave blank in dev to auto-use Ethereal.email ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="4F Store <no-reply@4fstore.example>"

# --- Admin ---
# Only this email is allowed to become ADMIN via Google login at /admin/login
ADMIN_EMAIL="you@example.com"

# --- App ---
PORT="3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
